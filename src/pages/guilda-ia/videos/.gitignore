# ─── Guilda de IA — Vídeos .gitignore ───
# Arquivos que FICAM no git: roteiros (.md), scripts (.py), thumbnails (.png)

# Vídeos finais e intermediários
videos/
synced/
quality_check/
quality_check*/

# Áudio TTS e processado
audio/
*.mp3
*.ogg
*.wav

# Cache do Manim (SVGs, partial_movie_files, renders)
media/
*/media/

# Cache Python
__pycache__/
*.pyc

# Backups
*.bak*
backup/

# Arquivos temporários
*.tmp
*.temp